[
  {
    "name": "@sigx/use",
    "path": "packages/use/dist/index.js",
    "ignore": ["@sigx/reactivity", "@sigx/runtime-core"],
    "limit": "6 KB"
  },
  {
    "name": "@sigx/use/web",
    "path": "packages/use/dist/web/index.js",
    "ignore": ["@sigx/reactivity", "@sigx/runtime-core"],
    "limit": "8 KB"
  },
  {
    "name": "@sigx/use { useToggle } (tree-shaking guard)",
    "path": "packages/use/dist/index.js",
    "import": "{ useToggle }",
    "ignore": ["@sigx/reactivity", "@sigx/runtime-core"],
    "limit": "300 B"
  },
  {
    "name": "@sigx/use/web { useEventListener } (tree-shaking guard)",
    "path": "packages/use/dist/web/index.js",
    "import": "{ useEventListener }",
    "ignore": ["@sigx/reactivity", "@sigx/runtime-core"],
    "limit": "700 B"
  }
]
