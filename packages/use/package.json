{
    "name": "@sigx/use",
    "version": "0.2.0",
    "description": "Composable utilities for SignalX — platform-agnostic tree-shakable functions built on sigx signals",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./internals": {
            "types": "./dist/internals.d.ts",
            "import": "./dist/internals.js"
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "tsgo",
        "dev": "tsgo --watch"
    },
    "keywords": [
        "sigx",
        "composables",
        "hooks",
        "utilities",
        "signals",
        "vueuse"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/use.git",
        "directory": "packages/use"
    },
    "homepage": "https://sigx.dev/use/",
    "bugs": {
        "url": "https://github.com/signalxjs/use/issues"
    },
    "devDependencies": {
        "@sigx/reactivity": "catalog:",
        "@sigx/runtime-core": "catalog:",
        "@types/node": "^25.9.1",
        "typescript": "^6.0.3"
    },
    "publishConfig": {
        "access": "public"
    },
    "peerDependencies": {
        "@sigx/reactivity": "catalog:",
        "@sigx/runtime-core": "catalog:"
    }
}
