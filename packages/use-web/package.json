{
    "name": "@sigx/use-web",
    "version": "0.1.1",
    "description": "Web platform pack for @sigx/use — SSR-safe DOM composables, re-exporting the platform-agnostic core",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "tsgo",
        "dev": "tsgo --watch"
    },
    "keywords": [
        "sigx",
        "composables",
        "hooks",
        "browser",
        "dom",
        "signals",
        "vueuse"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/use.git",
        "directory": "packages/use-web"
    },
    "homepage": "https://sigx.dev/use/",
    "bugs": {
        "url": "https://github.com/signalxjs/use/issues"
    },
    "devDependencies": {
        "@sigx/reactivity": "catalog:",
        "@sigx/runtime-core": "catalog:",
        "@sigx/runtime-dom": "catalog:",
        "@sigx/use": "workspace:^",
        "@types/node": "^25.9.1",
        "sigx": "catalog:",
        "typescript": "^6.0.3"
    },
    "publishConfig": {
        "access": "public"
    },
    "peerDependencies": {
        "@sigx/reactivity": "catalog:",
        "@sigx/runtime-core": "catalog:",
        "@sigx/use": ">=0.1.0 <0.2.0"
    }
}
