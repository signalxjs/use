{
  "name": "sigx-use-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Composable utilities for SignalX \u2014 VueUse-style tree-shakable functions built on sigx signals",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "sync:core": "node scripts/sync-core.mjs",
    "verify:catalog": "node scripts/check-catalog.mjs",
    "wt": "node scripts/worktree.mjs",
    "branch-protection": "node scripts/apply-branch-protection.mjs",
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsgo --noEmit",
    "typecheck:core": "tsgo --noEmit -p tsconfig.core.json",
    "lint": "oxlint packages/use/src packages/use-web/src",
    "lint:fix": "oxlint --fix packages/use/src packages/use-web/src",
    "clean": "node scripts/clean.mjs",
    "publish:dry": "node scripts/publish.js --dry-run",
    "publish:all": "node scripts/publish.js",
    "publish:beta": "node scripts/publish.js --tag beta",
    "version:set": "node scripts/bump-version.js",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major",
    "verify:pack": "node scripts/verify-pack.js",
    "size": "size-limit"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260510.1",
    "@vitest/coverage-v8": "^4.1.5",
    "happy-dom": "^20.9.0",
    "oxlint": "^1.47.0",
    "size-limit": "^11",
    "typescript": "^7.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "SignalX",
    "sigx",
    "composables",
    "hooks",
    "utilities",
    "signals",
    "vueuse"
  ],
  "author": "Andreas Ekdahl",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/signalxjs/use.git"
  },
  "homepage": "https://sigx.dev/use/",
  "bugs": {
    "url": "https://github.com/signalxjs/use/issues"
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
